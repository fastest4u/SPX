{
  "name": "spx-bidding-poller",
  "version": "1.0.0",
  "description": "Real-time polling for Agency Booking Bidding List (MVC TypeScript + React SPA)",
  "main": "dist/app.js",
  "scripts": {
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
    "typecheck:backend": "tsc --noEmit",
    "typecheck:frontend": "npx tsc --noEmit --project tsconfig.frontend-check.json",
    "build": "npm run typecheck --silent && rimraf dist && esbuild src/app.ts src/scripts/generate-migration.ts src/scripts/db-migrate.ts src/scripts/db-reset.ts src/scripts/db-test.ts src/scripts/smoke-test.ts src/scripts/test-memory-db.ts --bundle --platform=node --target=node18 --minify --outdir=dist --packages=external && npx vite build --emptyOutDir",
    "start": "node dist/app.js",
    "dev": "concurrently --kill-others --names backend,frontend --prefix-colors blue,green \"HTTP_ENABLED=true tsx src/app.ts\" \"vite\"",
    "watch": "tsc --watch",
    "db:generate": "npm run build --silent && node dist/scripts/generate-migration.js",
    "db:migrate": "npm run build --silent && node dist/scripts/db-migrate.js",
    "db:reset": "npm run build --silent && node dist/scripts/db-reset.js",
    "db:test": "npm run build --silent && node dist/scripts/db-test.js",
    "smoke:test": "npm run build --silent && node dist/scripts/smoke-test.js",
    "test:memory": "DB_MODE=memory npm run build --silent && DB_MODE=memory node dist/scripts/test-memory-db.js",
    "test:memory:quick": "DB_MODE=memory npx tsx src/scripts/test-memory-db.ts",
    "dev:memory": "cp .env.test .env && DB_MODE=memory npm run dev",
    "flow:test": "npm run db:migrate && npm run db:test",
    "dev:backend": "HTTP_ENABLED=true tsx src/app.ts",
    "dev:frontend": "vite",
    "frontend:build": "vite build --emptyOutDir",
    "flow:start": "npm run db:migrate && npm run build --silent && node dist/app.js"
  },
  "keywords": [
    "spx",
    "polling",
    "bidding",
    "logistics"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.0",
    "@tanstack/react-query": "^5.74.4",
    "@tanstack/react-router": "^1.117.1",
    "@tanstack/router-devtools": "^1.117.1",
    "@types/better-sqlite3": "^7.6.13",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "lucide-react": "^0.503.0",
    "mysql2": "^3.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.2.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@tanstack/router-plugin": "^1.117.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.0.0",
    "esbuild": "^0.28.0",
    "globals": "^16.0.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.1.4",
    "ts-node": "^10.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0",
    "vite": "^6.3.3"
  }
}
