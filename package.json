{
  "name": "spx-bidding-poller",
  "version": "1.0.0",
  "description": "Real-time polling for Agency Booking Bidding List (MVC TypeScript + React SPA)",
  "main": "dist/app.js",
  "scripts": {
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
    "typecheck:backend": "tsc --noEmit",
    "typecheck:frontend": "npx tsc --noEmit --project tsconfig.frontend-check.json",
    "test": "node scripts/run-tests.mjs",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "npm run typecheck --silent && rimraf dist && esbuild src/app.ts src/scripts/generate-migration.ts src/scripts/db-migrate.ts src/scripts/db-reset.ts src/scripts/db-test.ts src/scripts/smoke-test.ts src/scripts/test-memory-db.ts --bundle --platform=node --target=node24 --minify --outdir=dist --packages=external && npx vite build --emptyOutDir",
    "start": "node dist/app.js",
    "dev": "concurrently --kill-others --names backend,frontend --prefix-colors blue,green \"node scripts/dev-backend.mjs\" \"node scripts/dev-frontend.mjs\"",
    "watch": "tsc --watch",
    "db:generate": "npm run build --silent && node dist/scripts/generate-migration.js",
    "db:migrate": "npm run build --silent && node dist/scripts/db-migrate.js",
    "db:reset": "npm run build --silent && node dist/scripts/db-reset.js",
    "db:test": "npm run build --silent && node dist/scripts/db-test.js",
    "smoke:test": "npm run build --silent && node dist/scripts/smoke-test.js",
    "test:memory": "DB_MODE=memory npm run build --silent && DB_MODE=memory node dist/scripts/test-memory-db.js",
    "test:memory:quick": "DB_MODE=memory npx tsx src/scripts/test-memory-db.ts",
    "dev:memory": "cp .env.test .env && DB_MODE=memory npm run dev",
    "flow:test": "npm run db:migrate && npm run db:test",
    "test:e2e": "node scripts/run-e2e.mjs",
    "dev:backend": "node scripts/dev-backend.mjs",
    "dev:frontend": "node scripts/dev-frontend.mjs",
    "frontend:build": "vite build --emptyOutDir",
    "flow:start": "npm run db:migrate && npm run build --silent && node dist/app.js",
    "schema:verify": "node scripts/schema-verify.mjs",
    "verify": "npm run build"
  },
  "keywords": [
    "spx",
    "polling",
    "bidding",
    "logistics"
  ],
  "engines": {
    "node": ">=24.16.0"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/openai": "^3.0.64",
    "@evex/linejs": "npm:@jsr/evex__linejs@^2.6.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.0",
    "@tanstack/react-query": "^5.74.4",
    "@tanstack/react-router": "^1.117.1",
    "@tanstack/router-devtools": "^1.117.1",
    "@types/better-sqlite3": "^7.6.13",
    "ai": "^6.0.188",
    "ai-sdk-provider-codex-cli": "^1.2.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "lucide-react": "^0.503.0",
    "mysql2": "^3.9.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.2.0",
    "tailwindcss-animate": "^1.0.7",
    "undici": "^7.25.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@tailwindcss/vite": "^4.1.4",
    "@tanstack/router-plugin": "^1.117.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^16.0.0",
    "playwright": "^1.61.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.1.4",
    "ts-node": "^10.9.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^8.0.16"
  },
  "overrides": {
    "thrift": "0.23.0"
  }
}
