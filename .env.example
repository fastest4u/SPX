# ============================================
# SPX Bidding Poller - Environment Configuration
# ============================================

# --- Database Mode ---
# Set to "memory" for testing without MySQL (SQLite in-memory)
# Set to "mysql" or leave empty for production with real database
DB_MODE=mysql

# --- MySQL Database (required when DB_MODE=mysql or not set) ---
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# --- API Settings (required) ---
API_URL=https://logistics.myagencyservice.in.th/api/line_haul/agency/booking/bidding/list
COOKIE=fms_user_id=xxx; fms_user_skey=xxx
DEVICE_ID=your-device-id
APP_NAME=Agency Portal
REFERER=https://logistics.myagencyservice.in.th/

# --- Polling Settings ---
POLL_INTERVAL_MS=2000
BIDDING_PAGE_NO=1
BIDDING_PAGE_COUNT=100
REQUEST_TAB_PENDING_CONFIRMATION=true
REQUEST_CTIME_START=1776358800

# --- Features ---
DEBUG=false
FETCH_DETAILS=true
SAVE_TO_DB=true
NOTIFY_ENABLED=false
AUTO_ACCEPT_ENABLED=false

# --- Notification (required when NOTIFY_ENABLED=true) ---
# LINE_NOTIFY_TOKEN=xxx
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx
NOTIFY_MODE=batch

# --- Web UI (required when HTTP_ENABLED=true) ---
HTTP_ENABLED=true
HTTP_PORT=3000
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
COOKIE_SECRET=your-cookie-secret-at-least-32-chars
ADMIN_PASSWORD=your-admin-password-12-chars
ADMIN_USERNAME=admin
ADMIN_ROLE=admin
HTTP_ALLOWED_ORIGINS=https://your-domain.com
