# ============================================
# SPX Bidding Poller - Environment Configuration
# ============================================

# --- Runtime ---
NODE_ENV=production

# --- Database Mode ---
# "memory" = SQLite in-memory for local tests
# "mysql"  = production MySQL (default)
DB_MODE=mysql

# --- MySQL (required when DB_MODE=mysql) ---
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# --- Secrets ---
# JWT_SECRET and COOKIE_SECRET must each be at least 32 chars.
JWT_SECRET=replace-with-random-64-hex-or-longer
COOKIE_SECRET=replace-with-different-random-64-hex
# SECRETS_KEY (>=16 chars) drives AES-256-GCM encryption of LINE tokens, SPX
# COOKIE in app_settings, and the LINE bot session row. Without it the system
# falls back to JWT_SECRET+COOKIE_SECRET, but rotating those will then drop
# the ability to read previously-encrypted secrets.
SECRETS_KEY=replace-with-random-96-hex

# --- SPX upstream ---
API_URL=https://logistics.myagencyservice.in.th/api/line_haul/agency/booking/bidding/list
COOKIE=fms_user_id=xxx; fms_user_skey=xxx
DEVICE_ID=your-device-id
APP_NAME=Agency Portal
REFERER=https://logistics.myagencyservice.in.th/

# --- Polling ---
POLL_INTERVAL_MS=30000
BIDDING_PAGE_NO=1
BIDDING_PAGE_COUNT=100
REQUEST_TAB_PENDING_CONFIRMATION=true
REQUEST_CTIME_START=1776358800
BIDDING_VEHICLE_TYPE=13

# --- Features ---
DEBUG=false
FETCH_DETAILS=true
SAVE_TO_DB=true
NOTIFY_ENABLED=false
AUTO_ACCEPT_ENABLED=false

# --- Notification (optional) ---
# LINE_CHANNEL_ACCESS_TOKEN=xxx
# LINE_USER_ID=xxx
# LINEJS_TEST_ENABLED=false
# LINEJS_TEST_TARGET_ID=xxx
# LINEJS_TEST_TARGET_ID_AUTO_ACCEPT_SUCCESS=
# LINEJS_TEST_TARGET_ID_AUTO_ACCEPT_FAILURE=
# LINEJS_TEST_DEVICE=IOSIPAD
# LINEJS_TEST_STORAGE_PATH=data/linejs-storage.json
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx
# LINE_IMAGE_LISTENER_CHAT_ID=
NOTIFY_MODE=batch

# --- Web UI ---
HTTP_ENABLED=true
HTTP_PORT=3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-12-chars-or-more
ADMIN_ROLE=admin
HTTP_ALLOWED_ORIGINS=https://your-domain.com

# --- Codex OCR (optional) ---
CODEX_IMAGE_PROVIDER=auto
CODEX_IMAGE_MODEL=
