{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/session-start.mjs",
        "failClosed": false
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/hooks/self-check.mjs",
        "failClosed": true,
        "matcher": "(production|prod|deploy|schema|db|database|migration|auth|secret|token|password|billing|payment|delete|drop|reset|rewrite|refactor|multi-file)"
      }
    ],
    "sessionEnd": [
      {
        "command": "node .cursor/hooks/session-end-automation.mjs",
        "failClosed": false
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/stop.mjs",
        "failClosed": false
      }
    ]
  }
}