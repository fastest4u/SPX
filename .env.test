# Test environment - SQLite in-memory (no MySQL needed)
# Copy to .env for testing without DB.
DB_MODE=memory
NODE_ENV=development
HTTP_ENABLED=true
HTTP_PORT=3000

JWT_SECRET=test-jwt-secret-at-least-32-characters-long-123
COOKIE_SECRET=test-cookie-secret-at-least-32-chars-12345
SECRETS_KEY=test-secrets-key-at-least-16-chars-123456789

ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456789012
ADMIN_ROLE=admin
HTTP_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# API settings (optional for basic testing)
API_URL=https://logistics.myagencyservice.in.th/api/line_haul/agency/booking/bidding/list
COOKIE=fms_user_id=213007; fms_user_skey=test
DEVICE_ID=test-device-id-123456789012345
APP_NAME=Agency Portal
REFERER=https://logistics.myagencyservice.in.th/

DEBUG=true
FETCH_DETAILS=true
SAVE_TO_DB=true
NOTIFY_ENABLED=false
AUTO_ACCEPT_ENABLED=false
POLL_INTERVAL_MS=2000
BIDDING_PAGE_NO=1
BIDDING_PAGE_COUNT=100
REQUEST_TAB_PENDING_CONFIRMATION=true
REQUEST_CTIME_START=1776358800
